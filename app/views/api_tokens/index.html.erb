<div class="page-header">
  <h1 class="page-title">API Tokens</h1>
  <p class="page-subtitle">Manage tokens for the Obsidian plugin and API access</p>
</div>

<% if @new_token %>
  <div class="token-warning">
    <strong>Copy your new token now!</strong> It will only be shown once.
  </div>
  <div class="token-display"><%= @new_token %></div>
<% end %>

<div class="card mb-6">
  <h3 class="card-title">Create a new token</h3>
  <p class="card-subtitle">Tokens are used to authenticate the Obsidian plugin or API requests.</p>

  <%= form_with url: api_tokens_path, class: "mt-4" do |form| %>
    <div class="form-group">
      <%= form.label :name, "Token name", class: "form-label" %>
      <%= form.text_field :name, placeholder: "e.g., Obsidian Plugin", class: "form-input", style: "max-width: 300px;" %>
      <p class="form-hint">A friendly name to identify this token</p>
    </div>
    <%= form.submit "Create token", class: "btn btn-primary" %>
  <% end %>
</div>

<div class="card">
  <h3 class="card-title">Active tokens</h3>

  <% if @tokens.any? %>
    <div class="table-container mt-4">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Created</th>
            <th>Last used</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @tokens.each do |token| %>
            <tr>
              <td><strong><%= token.name %></strong></td>
              <td><%= token.created_at.strftime("%b %d, %Y") %></td>
              <td>
                <% if token.last_used_at %>
                  <%= time_ago_in_words(token.last_used_at) %> ago
                <% else %>
                  <span style="color: var(--color-gray-400);">Never</span>
                <% end %>
              </td>
              <td class="text-right">
                <%= button_to "Revoke", api_token_path(token), method: :delete, class: "btn btn-danger btn-small", data: { turbo_confirm: "Are you sure you want to revoke this token? This cannot be undone." } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-state-icon">&#128273;</div>
      <div class="empty-state-title">No active tokens</div>
      <p>Create a token above to get started with the API.</p>
    </div>
  <% end %>
</div>

<div class="card mt-6">
  <h3 class="card-title">Using the API</h3>
  <p style="color: var(--color-gray-600); margin-top: 0.5rem;">
    Include your token in the <code style="background: var(--color-gray-100); padding: 0.125rem 0.375rem; border-radius: 4px;">Authorization</code> header:
  </p>
  <pre style="background: var(--color-gray-800); color: #10b981; padding: 1rem; border-radius: var(--radius); margin-top: 1rem; overflow-x: auto; font-size: 0.875rem;">Authorization: Bearer your-token-here</pre>

  <h4 style="font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem;">API Endpoints</h4>
  <ul style="margin-left: 1.5rem; color: var(--color-gray-600); font-size: 0.9375rem;">
    <li><code>GET /api/v1/me</code> - Get your account info</li>
    <li><code>GET /api/v1/entries</code> - List your journal entries</li>
    <li><code>GET /api/v1/entries/:id/markdown</code> - Get entry as Obsidian markdown</li>
    <li><code>POST /api/v1/entries/:id/mark_synced</code> - Mark entry as synced</li>
  </ul>
</div>
