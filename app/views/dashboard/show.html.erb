<div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: center;">
  <h1 class="dashboard-title">Dashboard</h1>
  <div style="display: flex; gap: 0.5rem;">
    <%= link_to "Capture", camera_path, class: "btn btn-primary" %>
    <%= link_to "Upload", new_upload_path, class: "btn btn-secondary" %>
  </div>
</div>

<% if @credit_balance == 0 %>
  <div class="alert alert-warning" style="margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
    <div>
      <strong>You're out of credits!</strong> Buy credits to transcribe your journal pages.
    </div>
    <%= link_to "Buy credits", new_payment_path, class: "btn btn-primary btn-small" %>
  </div>
<% end %>

<div class="dashboard-grid">
  <div class="stat-card">
    <div class="stat-label">Credit Balance</div>
    <div class="stat-value"><%= @credit_balance %> <span style="font-size: 1rem; font-weight: normal; color: var(--color-gray-500);">pages</span></div>
    <div class="stat-action">
      <%= link_to "Buy more credits", new_payment_path, class: "btn btn-primary btn-small" %>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-label">Journal Entries</div>
    <div class="stat-value"><%= @recent_entries.count %></div>
    <div class="stat-action">
      <span class="badge badge-info">Last 30 days</span>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-label">API Access</div>
    <div class="stat-value"><%= Current.user.api_tokens.active.count %> <span style="font-size: 1rem; font-weight: normal; color: var(--color-gray-500);">tokens</span></div>
    <div class="stat-action">
      <%= link_to "Manage tokens", api_tokens_path, class: "btn btn-secondary btn-small" %>
    </div>
  </div>
</div>

<% awaiting_jobs = @pending_jobs.select(&:awaiting_credits?) %>
<% processing_jobs = @pending_jobs.reject(&:awaiting_credits?) %>

<% if awaiting_jobs.any? %>
  <div class="section mt-8">
    <h2 class="section-title">Awaiting Credits</h2>
    <div class="alert alert-warning" style="margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between;">
      <div>
        You have <strong><%= awaiting_jobs.sum(&:page_count) %> pages</strong> waiting for credits.
      </div>
      <%= link_to "Buy credits", new_payment_path, class: "btn btn-primary btn-small" %>
    </div>
    <div class="card">
      <% awaiting_jobs.each do |job| %>
        <div class="entry-item">
          <div>
            <span class="entry-date">Job #<%= job.id %></span>
            <span class="entry-meta"> - <%= job.page_count %> pages</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="badge badge-warning">Needs <%= job.page_count %> credits</span>
            <% if @credit_balance > 0 %>
              <%= button_to "Process #{@credit_balance} now",
                  process_partial_transcription_job_path(job),
                  class: "btn btn-secondary btn-small",
                  data: { turbo_confirm: "This will process only #{@credit_balance} of #{job.page_count} pages. The remaining pages will be skipped. Continue?" } %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if processing_jobs.any? %>
  <div class="section mt-8">
    <h2 class="section-title">Processing</h2>
    <div class="card">
      <% processing_jobs.each do |job| %>
        <div class="entry-item">
          <div>
            <span class="entry-date">Job #<%= job.id %></span>
            <span class="entry-meta"> - <%= job.page_count %> pages</span>
          </div>
          <span class="badge badge-warning"><%= job.status.humanize %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="section mt-8">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <h2 class="section-title" style="margin-bottom: 0;">Recent Entries</h2>
    <% if @recent_entries.any? %>
      <%= link_to export_path, method: :post, class: "btn btn-secondary btn-small" do %>
        &#128230; Export All (ZIP)
      <% end %>
    <% end %>
  </div>
  <div class="card" style="margin-top: 1rem;">
    <% if @recent_entries.any? %>
      <ul class="entry-list">
        <% @recent_entries.each do |entry| %>
          <li class="entry-item">
            <div>
              <span class="entry-date"><%= entry.entry_date&.strftime("%B %d, %Y") || entry.title %></span>
              <span class="entry-meta"> - <%= truncate(entry.content, length: 60) %></span>
            </div>
            <div class="entry-actions">
              <% days = entry.days_until_expiry %>
              <% if days && days > 0 %>
                <span class="badge badge-<%= entry.expiry_urgency == :ok ? 'success' : (entry.expiry_urgency == :warning ? 'warning' : 'danger') %>">
                  Expires in <%= days %> <%= 'day'.pluralize(days) %>
                </span>
              <% end %>
              <% if entry.synced %>
                <span class="badge badge-success">Synced</span>
              <% else %>
                <span class="badge badge-info">Pending sync</span>
              <% end %>
              <%= link_to download_entry_path(entry), class: "btn btn-secondary btn-small", title: "Download as Markdown" do %>
                &#8595; MD
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="empty-state">
        <div class="empty-state-icon">&#128221;</div>
        <div class="empty-state-title">No journal entries yet</div>
        <p>Capture photos of your handwritten journals to get started.</p>
        <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
          <%= link_to "Capture your first page", camera_path, class: "btn btn-primary" %>
          <%= link_to "Upload images", new_upload_path, class: "btn btn-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="section mt-8">
  <h2 class="section-title">Quick Start Guide</h2>
  <div class="card">
    <ol style="margin-left: 1.5rem; color: var(--color-gray-600);">
      <li style="margin-bottom: 0.75rem;"><strong>Buy credits</strong> - Each page costs 1 credit (~$0.10)</li>
      <li style="margin-bottom: 0.75rem;"><strong>Upload photos</strong> - Use our API to submit journal page images</li>
      <li style="margin-bottom: 0.75rem;"><strong>Get an API token</strong> - <%= link_to "Create a token", api_tokens_path %> for the Obsidian plugin</li>
      <li><strong>Sync to Obsidian</strong> - Install the Journalizer plugin and enter your token</li>
    </ol>
  </div>
</div>
