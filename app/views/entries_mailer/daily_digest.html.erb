<h1>Your Daily Digest</h1>

<p>Hi<%= @user.display_name.present? ? " #{@user.display_name.split.first}" : "" %>!</p>

<p>Here <%= @entries.count == 1 ? "is" : "are" %> your <%= @entries.count %> <%= "entry".pluralize(@entries.count) %> from the past 24 hours:</p>

<% @entries.each do |entry| %>
  <div style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin: 16px 0;">
    <% if entry.entry_date %>
      <p style="color: #666; margin: 0 0 8px 0; font-size: 13px;"><%= entry.entry_date.strftime("%B %d, %Y") %></p>
    <% end %>
    <h3 style="margin: 0 0 12px 0; font-size: 16px; color: #1a1a1a;"><%= entry.title %></h3>
    <p style="color: #444; white-space: pre-wrap; margin: 0;"><%= entry.content.truncate(300) %></p>
  </div>
<% end %>

<p><a href="<%= entries_url %>" class="btn">View All Entries</a></p>

<p class="muted">You're receiving this daily digest. <a href="<%= account_url %>">Manage preferences</a></p>
