<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Journalizer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Journalizer">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="Transcribe handwritten journal entries and sync to Obsidian">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <nav class="navbar">
        <div class="nav-brand">
          <%= link_to "Journalizer", root_path %>
        </div>
        <div class="nav-links">
          <%= link_to "Capture", camera_path, class: "nav-link" %>
          <%= link_to "Upload", new_upload_path, class: "nav-link" %>
          <%= link_to "Buy Credits", new_payment_path, class: "nav-link" %>
          <%= link_to "API Tokens", api_tokens_path, class: "nav-link hide-mobile" %>
          <%= link_to "Account", account_path, class: "nav-link hide-mobile" %>
        </div>
        <div class="nav-user">
          <% if Current.user.avatar_url.present? %>
            <img src="<%= Current.user.avatar_url %>" alt="" class="avatar">
          <% end %>
          <%= link_to account_path, class: "credit-badge" do %><%= Current.user.credit_balance %> credits<% end %>
          <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-small btn-ghost" %>
        </div>
      </nav>
    <% end %>

    <% if flash[:notice] %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <main class="<%= authenticated? ? 'main-content' : 'main-content-full' %>">
      <%= yield %>
    </main>

    <% unless authenticated? %>
      <footer class="footer">
        <p>Journalizer is <a href="https://github.com/henryaj/journalizer-web" target="_blank">open source</a>. Your data is yours.</p>
      </footer>
    <% end %>

    <% if authenticated? %>
      <div id="feedback_widget" data-controller="feedback-widget">
        <button type="button" class="feedback-button" data-feedback-widget-target="button" data-action="click->feedback-widget#toggle" title="Send feedback">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </button>

        <div class="feedback-panel" data-feedback-widget-target="panel" style="display: none;">
          <div class="feedback-panel-header">
            <span class="feedback-panel-title">Send Feedback</span>
            <button type="button" class="feedback-close" data-action="click->feedback-widget#close">&times;</button>
          </div>
          <%= form_with url: feedback_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
            <textarea name="message" rows="4" placeholder="Bug report, feature request, or just say hi..." data-feedback-widget-target="textarea" class="feedback-textarea"></textarea>
            <button type="submit" class="btn btn-primary btn-full">Send</button>
          <% end %>
        </div>
      </div>
    <% end %>
  </body>
</html>
