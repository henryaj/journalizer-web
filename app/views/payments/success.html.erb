<div class="auth-container">
  <div class="card" style="max-width: 500px; text-align: center;">
    <div style="font-size: 4rem; margin-bottom: 1rem;">&#127881;</div>
    <h1 style="font-size: 1.5rem; font-weight: 700; color: var(--color-gray-900); margin-bottom: 0.5rem;">Payment successful!</h1>
    <p style="color: var(--color-gray-600); margin-bottom: 1.5rem;">
      Your credits have been added to your account.
    </p>
    <div style="background: var(--color-gray-100); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem;">
      <div style="font-size: 0.875rem; color: var(--color-gray-500);">New balance</div>
      <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-primary);"><%= @credits %> credits</div>
    </div>
    <%= link_to "Go to Dashboard", root_path, class: "btn btn-primary" %>
  </div>
</div>
