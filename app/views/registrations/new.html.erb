<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">Journalizer</div>
      <h1 class="auth-title">Create an account</h1>
      <p class="auth-subtitle">Start transcribing your journals</p>
    </div>

    <%= link_to "/auth/google_oauth2", class: "btn btn-google btn-full", data: { turbo: false } do %>
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Sign up with Google
    <% end %>

    <div class="auth-divider">
      <span>or sign up with email</span>
    </div>

    <%= form_with model: @user, url: registration_path, class: "auth-form" do |form| %>
      <% if @user.errors.any? %>
        <div id="error_explanation">
          <h2><%= pluralize(@user.errors.count, "error") %> prohibited this account from being created:</h2>
          <ul>
            <% @user.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= form.label :email_address, "Email", class: "form-label" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= form.label :password, class: "form-label" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "At least 8 characters", minlength: 8, class: "form-input" %>
        <p class="form-hint">Must be at least 8 characters</p>
      </div>

      <div class="form-group">
        <%= form.label :password_confirmation, "Confirm password", class: "form-label" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm your password", class: "form-input" %>
      </div>

      <%= form.submit "Create account", class: "btn btn-primary btn-full" %>
    <% end %>

    <div class="auth-footer">
      <p>Already have an account? <%= link_to "Sign in", new_session_path %></p>
    </div>
  </div>
</div>
