<div class="upload-container">
  <div class="upload-header">
    <h1 class="upload-title">Upload Journal Pages</h1>
    <p class="upload-subtitle">Select images from your device — double page spreads work great</p>
    <p class="upload-hint-date">Dates are detected automatically from your handwriting</p>
  </div>

  <div class="upload-mode-switch">
    <%= link_to camera_path, class: "mode-option" do %>
      <span class="mode-icon">📷</span>
      <span class="mode-label">Use Camera</span>
    <% end %>
  </div>

  <%= form_with url: uploads_path, method: :post, multipart: true, id: "upload-form", class: "upload-form", data: { controller: "upload" } do |f| %>
    <div class="upload-zone" data-upload-target="dropzone">
      <div class="upload-zone-content" data-upload-target="placeholder">
        <div class="upload-icon">📁</div>
        <p class="upload-prompt">Tap to select images</p>
        <p class="upload-hint">Supports JPG, PNG, HEIC</p>
      </div>

      <div class="preview-container" data-upload-target="previewContainer" style="display: none;">
        <div class="preview-grid" data-upload-target="previewGrid"></div>

        <div class="orientation-toolbar">
          <span class="orientation-label">Rotate photos:</span>
          <div class="orientation-buttons">
            <label class="orientation-btn" title="No rotation">
              <input type="radio" name="orientation" value="0" checked data-action="change->upload#updateRotation">
              <span class="orientation-btn-inner">0°</span>
            </label>
            <label class="orientation-btn" title="Rotate 90° clockwise">
              <input type="radio" name="orientation" value="90" data-action="change->upload#updateRotation">
              <span class="orientation-btn-inner">↻ 90°</span>
            </label>
            <label class="orientation-btn" title="Rotate 180°">
              <input type="radio" name="orientation" value="180" data-action="change->upload#updateRotation">
              <span class="orientation-btn-inner">↻ 180°</span>
            </label>
            <label class="orientation-btn" title="Rotate 90° counter-clockwise">
              <input type="radio" name="orientation" value="270" data-action="change->upload#updateRotation">
              <span class="orientation-btn-inner">↺ 90°</span>
            </label>
          </div>
        </div>

        <div class="year-toolbar">
          <label class="year-label" for="year">Year these entries are from:</label>
          <select name="year" id="year" class="year-select">
            <option value="">Auto-detect</option>
            <% (Date.current.year).downto(Date.current.year - 20).each do |y| %>
              <option value="<%= y %>"><%= y %></option>
            <% end %>
          </select>
        </div>

        <button type="button" class="btn btn-secondary btn-small add-more-btn" data-action="click->upload#addMore">
          + Add more pages
        </button>
      </div>

      <input type="file"
             name="images[]"
             id="images"
             accept="image/*"
             multiple
             data-upload-target="input"
             data-action="change->upload#handleFiles"
             class="upload-input">
    </div>

    <div class="upload-actions">
      <div class="credit-info">
        <span class="credit-balance"><%= Current.user.credit_balance %> credits available</span>
        <span class="credit-cost" data-upload-target="costDisplay">Select images to see cost</span>
      </div>

      <%= f.submit "Continue to Review", class: "btn btn-primary btn-large btn-full", data: { upload_target: "submit", action: "click->upload#showLoading" }, disabled: true %>
      <div class="upload-loading" data-upload-target="loading" style="display: none;">
        <div class="upload-loading-spinner"></div>
        <p>Uploading images...</p>
      </div>
    </div>
  <% end %>
</div>
